# Production: your Vercel URL (e.g. https://erpchat.vercel.app)
FRONTEND_URL=

GROQ_API_KEY=
GROQ_MODEL_ID=llama-3.1-8b-instant
LLM_TEMPERATURE=0.0

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# RAG — PDF knowledge base -> Pinecone (erp_schema.json is only for SQL validation)
KNOWLEDGE_SCHEMA_PDF=app/knowledge/schema.pdf
KNOWLEDGE_RULES_PDF=app/knowledge/business_logic.pdf
KNOWLEDGE_VERSION=1.0.0
PDF_CHUNK_MAX_CHARS=2000
RAG_TOP_K=8
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=erp-analyst
PINECONE_NAMESPACE=

DETERMINISTIC_MODE=true
MAX_SQL_RETRIES=3
SQL_ROW_LIMIT=1000
SQL_COMPLEXITY_MAX_JOINS=6

MULTI_STEP_ENABLED=true
MAX_TARGETS=5
MAX_SQL_RETRIES_PER_TARGET=3

# strict_word_similarity bands (Step 1+ entity match)
ENTITY_MATCH_EXCELLENT_MIN=0.8
ENTITY_MATCH_FAIR_MIN=0.4
ENTITY_MATCH_AMBIGUITY_GAP=0.05
ENTITY_MATCH_CANDIDATE_LIMIT=10

PROMPT_VERSION_PLANNER=planner-v2.0
PROMPT_VERSION_SQL=sql-v2.0
PROMPT_VERSION_PYTHON=python-v1.0
PROMPT_VERSION_INSIGHT=insight-v2.0
